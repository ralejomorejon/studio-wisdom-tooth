{
  "name": "wisdom-tooth",
  "private": true,
  "version": "1.0.0",
  "main": "package.json",
  "license": "UNLICENSED",
  "scripts": {
    "build": "sanity build",
    "deploy": "sanity deploy",
    "deploy-graphql": "sanity graphql deploy",
    "dev": "sanity dev",
    "start": "sanity start",
    "sanity:migrate-category-refs:check": "node migrate-category-references.mjs",
    "sanity:migrate-category-refs:apply": "node migrate-category-references.mjs --apply",
    "sanity:migrate-category-refs:apply-clean": "node migrate-category-references.mjs --apply --unset-legacy",
    "sanity:sync-category-docs:check": "node sync-category-docs-from-products.mjs",
    "sanity:sync-category-docs:apply": "node sync-category-docs-from-products.mjs --apply",
    "sanity:fix-category-keys:check": "node fix-category-reference-keys.mjs",
    "sanity:fix-category-keys:apply": "node fix-category-reference-keys.mjs --apply",
    "sanity:fix-images:check": "node fix-broken-product-images.mjs",
    "sanity:fix-images:apply": "node fix-broken-product-images.mjs --apply"
  },
  "keywords": [
    "sanity"
  ],
  "dependencies": {
    "@sanity/vision": "^5.21.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanity": "^5.21.0",
    "styled-components": "^6.1.18"
  },
  "devDependencies": {
    "@sanity/eslint-config-studio": "^6.0.0",
    "@types/react": "^19.2.14",
    "eslint": "^9.28",
    "prettier": "^3.5",
    "typescript": "^5.8",
    "wrangler": "^4.78.0"
  },
  "prettier": {
    "bracketSpacing": false,
    "printWidth": 100,
    "semi": false,
    "singleQuote": true
  }
}
